{
  "name": "stable-georgia-console",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17 <22"
  },
  "scripts": {
    "check:node": "node -e \"const major=Number(process.versions.node.split('.')[0]); if(!Number.isFinite(major)||major<18||major>=22){console.error('Unsupported Node.js version: '+process.version+'. Use Node 20 (recommended).'); process.exit(1);}\"",
    "dev": "pnpm run check:node && next dev",
    "build": "pnpm run check:node && next build",
    "start": "pnpm run check:node && next start",
    "lint": "next lint"
  },
  "dependencies": {
    "ably": "^2.21.0",
    "next": "14.1.0",
    "react": "^18",
    "react-dom": "^18",
    "thirdweb": "^5.119.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
